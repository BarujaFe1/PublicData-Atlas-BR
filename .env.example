# PublicData Atlas BR — environment template
# Copy to .env and fill values. Never commit real secrets.

# Backend
ATLAS_ENV=development
ATLAS_DOMAIN=education
DUCKDB_PATH=./data/gold/atlas.duckdb
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Frontend (Next.js)
NEXT_PUBLIC_API_BASE=http://127.0.0.1:8000
NEXT_PUBLIC_MAP_STYLE_URL=

# Optional ingestion
GITHUB_TOKEN=
